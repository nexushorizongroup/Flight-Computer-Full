(netlist
  (version 4)
  (design
    (source "Generated by assistant")
    (date "2026-05-14")
    (comment "High-power rocket flight computer single-sheet netlist")
  )

  ; Nets
  (nets
    (net (code 1) (name GND))
    (net (code 2) (name BAT+))
    (net (code 3) (name BAT-))
    (net (code 4) (name SW_OUT+))
    (net (code 5) (name FUSE_OUT+))
    (net (code 6) (name VIN_5V))
    (net (code 7) (name VCC_5V))
    (net (code 8) (name VCC_3V3))
    (net (code 9) (name I2C_SDA))
    (net (code 10) (name I2C_SCL))
    (net (code 11) (name I2C_TCA_CH0))
    (net (code 12) (name I2C_TCA_CH1))
    (net (code 13) (name I2C_TCA_CH2))
    (net (code 14) (name I2C_TCA_CH3))
    (net (code 15) (name UART1_TX))
    (net (code 16) (name UART1_RX))
    (net (code 17) (name SPI_SCK))
    (net (code 18) (name SPI_MOSI))
    (net (code 19) (name SPI_MISO))
    (net (code 20) (name LORA_CS))
    (net (code 21) (name SD_CS))
    (net (code 22) (name PYRO_CTRL))
    (net (code 23) (name PWR_GOOD_5V))
    (net (code 24) (name PWR_GOOD_3V3))
    (net (code 25) (name INA3221_SHUNT_BAT))
    (net (code 26) (name INA3221_SHUNT_5V))
    (net (code 27) (name INA3221_SHUNT_3V3))
    (net (code 28) (name RTC_VBAT))
    (net (code 29) (name ANT_GPS))
    (net (code 30) (name ANT_LORA))
  )

  ; Components
  (components
    ; Battery connector
    (comp (ref BAT1) (value "XT30/PH2") (footprint "Connector_Generic:Conn_01x02") (datasheet "")
      (fields (field (name Reference) (value BAT1)))
      (libsource (lib "Connector_Generic") (part "Conn_01x02"))
      (pins
        (pin (num 1) (name +) (type PWR) (net BAT+))
        (pin (num 2) (name -) (type PWR) (net BAT-))
      )
    )

    ; Quick-break fuse (2A)
    (comp (ref FUSE1) (value "2A_quick-break") (footprint "Fuse:THT_FUSE_2A") (datasheet "")
      (pins
        (pin (num 1) (name A) (type PWR) (net BAT+))
        (pin (num 2) (name B) (type PWR) (net FUSE_OUT+))
      )
    )

    ; Power switch
    (comp (ref SW1) (value "Slide_Switch") (footprint "Switch_THT:SW_SPDT") (datasheet "")
      (pins
        (pin (num 1) (name COM) (type PWR) (net FUSE_OUT+))
        (pin (num 2) (name NO) (type PWR) (net SW_OUT+))
        (pin (num 3) (name NC) (type PWR) (net UNUSED))
      )
    )

    ; BMS (2S 5A)
    (comp (ref BMS1) (value "2S_5A_BMS") (footprint "Generic_Module:BMS_2S") (datasheet "")
      (pins
        (pin (num 1) (name BATT+) (type PWR) (net BAT+))
        (pin (num 2) (name BATT-) (type PWR) (net BAT-))
        (pin (num 3) (name PACK+) (type PWR) (net SW_OUT+))
        (pin (num 4) (name PACK-) (type PWR) (net BAT-))
        (pin (num 5) (name CHG+) (type PWR) (net BAT+))
        (pin (num 6) (name CHG-) (type PWR) (net BAT-))
      )
    )

    ; MP1584EN Buck converter module
    (comp (ref U_BUCK) (value "MP1584EN_module") (footprint "Module:MP1584_Module") (datasheet "")
      (pins
        (pin (num 1) (name VIN) (type PWR) (net SW_OUT+))
        (pin (num 2) (name GND) (type PWR) (net GND))
        (pin (num 3) (name VOUT) (type PWR) (net VIN_5V))
        (pin (num 4) (name ADJ) (type PASSIVE) (net UNUSED))
      )
    )

    ; AMS1117 3.3V regulator
    (comp (ref U_3V3) (value "AMS1117-3.3") (footprint "Regulator_SOT-223:AMS1117-3.3") (datasheet "")
      (pins
        (pin (num 1) (name IN) (type PWR) (net VIN_5V))
        (pin (num 2) (name GND) (type PWR) (net GND))
        (pin (num 3) (name OUT) (type PWR) (net VCC_3V3))
      )
    )

    ; Power Good signals (voltage divider / PGOOD outputs)
    (comp (ref R_PG5) (value "10k") (footprint "R_Axial") (datasheet "")
      (pins (pin (num 1) (name 1) (type PASSIVE) (net VIN_5V)) (pin (num 2) (name 2) (type PASSIVE) (net PWR_GOOD_5V)))
    (comp (ref R_PG3) (value "10k") (footprint "R_Axial") (datasheet "")
      (pins (pin (num 1) (name 1) (type PASSIVE) (net VCC_3V3)) (pin (num 2) (name 2) (type PASSIVE) (net PWR_GOOD_3V3)))

    ; INA3221 (I2C triple-channel shunt monitor)
    (comp (ref U_INA) (value "INA3221") (footprint "SOT-23-8:INA3221") (datasheet "")
      (pins
        (pin (num 1) (name VCC) (type PWR) (net VCC_3V3))
        (pin (num 2) (name GND) (type PWR) (net GND))
        (pin (num 3) (name SDA) (type I/O) (net I2C_SDA))
        (pin (num 4) (name SCL) (type I/O) (net I2C_SCL))
        (pin (num 5) (name CH1_IN+) (type PASSIVE) (net INA3221_SHUNT_BAT))
        (pin (num 6) (name CH1_IN-) (type PASSIVE) (net BAT-))
        (pin (num 7) (name CH2_IN+) (type PASSIVE) (net INA3221_SHUNT_5V))
        (pin (num 8) (name CH2_IN-) (type PASSIVE) (net GND))
        ; Note: mapping for CH3 uses same footprint pins; logical nets defined in BOM/wiring
      )
    )

    ; TCA9548A I2C multiplexer
    (comp (ref U_TCA) (value "TCA9548A") (footprint "TSSOP-16:TCA9548A") (datasheet "")
      (pins
        (pin (num 1) (name VCC) (type PWR) (net VCC_3V3))
        (pin (num 2) (name GND) (type PWR) (net GND))
        (pin (num 3) (name SDA) (type I/O) (net I2C_SDA))
        (pin (num 4) (name SCL) (type I/O) (net I2C_SCL))
        (pin (num 5) (name CH0_SDA) (type I/O) (net I2C_TCA_CH0))
        (pin (num 6) (name CH0_SCL) (type I/O) (net I2C_TCA_CH0))
        (pin (num 7) (name CH1_SDA) (type I/O) (net I2C_TCA_CH1))
        (pin (num 8) (name CH1_SCL) (type I/O) (net I2C_TCA_CH1))
        (pin (num 9) (name CH2_SDA) (type I/O) (net I2C_TCA_CH2))
        (pin (num 10) (name CH2_SCL) (type I/O) (net I2C_TCA_CH2))
        (pin (num 11) (name CH3_SDA) (type I/O) (net I2C_TCA_CH3))
        (pin (num 12) (name CH3_SCL) (type I/O) (net I2C_TCA_CH3))
      )
    )

    ; ESP32-S3 N16R8 dev board (module block)
    (comp (ref U_ESP32) (value "ESP32-S3-N16R8_devkit") (footprint "Module:ESP32-S3-DevKit-N16R8") (datasheet "")
      (pins
        (pin (num 1) (name VIN5V) (type PWR) (net VIN_5V))
        (pin (num 2) (name 3V3) (type PWR) (net VCC_3V3))
        (pin (num 3) (name GND) (type PWR) (net GND))
        (pin (num 4) (name SDA) (type I/O) (net I2C_SDA))
        (pin (num 5) (name SCL) (type I/O) (net I2C_SCL))
        (pin (num 6) (name UART1_TX) (type I/O) (net UART1_TX))
        (pin (num 7) (name UART1_RX) (type I/O) (net UART1_RX))
        (pin (num 8) (name SPI_SCK) (type I/O) (net SPI_SCK))
        (pin (num 9) (name SPI_MOSI) (type I/O) (net SPI_MOSI))
        (pin (num 10) (name SPI_MISO) (type I/O) (net SPI_MISO))
        (pin (num 11) (name GPIO_PYRO) (type I/O) (net PYRO_CTRL))
        (pin (num 12) (name INT1) (type I/O) (net UNUSED))
        (pin (num 13) (name BOOT0) (type PWR) (net UNUSED))
        (pin (num 14) (name EN) (type PWR) (net UNUSED))
      )
    )

    ; ICM20948 IMU
    (comp (ref U_ICM) (value "ICM20948") (footprint "LGA_24:ICM20948") (datasheet "")
      (pins
        (pin (num 1) (name VCC) (type PWR) (net VCC_3V3))
        (pin (num 2) (name GND) (type PWR) (net GND))
        (pin (num 3) (name SDA) (type I/O) (net I2C_TCA_CH1))
        (pin (num 4) (name SCL) (type I/O) (net I2C_TCA_CH1))
        (pin (num 5) (name INT) (type I/O) (net UNUSED))
      )
    )

    ; GY-91 (optional) - mapped to TCA channel 1 if used; note possible sensor duplication
    (comp (ref U_GY91) (value "GY-91") (footprint "Module:GY-91") (datasheet "")
      (pins
        (pin (num 1) (name VCC) (type PWR) (net VCC_3V3))
        (pin (num 2) (name GND) (type PWR) (net GND))
        (pin (num 3) (name SDA) (type I/O) (net I2C_TCA_CH1))
        (pin (num 4) (name SCL) (type I/O) (net I2C_TCA_CH1))
      )
    )

    ; MS5611 Barometer (I2C)
    (comp (ref U_MS5) (value "MS5611") (footprint "Module:MS5611") (datasheet "")
      (pins
        (pin (num 1) (name VCC) (type PWR) (net VCC_3V3))
        (pin (num 2) (name GND) (type PWR) (net GND))
        (pin (num 3) (name SDA) (type I/O) (net I2C_TCA_CH2))
        (pin (num 4) (name SCL) (type I/O) (net I2C_TCA_CH2))
      )
    )

    ; DS3231 RTC
    (comp (ref U_RTC) (value "DS3231") (footprint "SO-8:DS3231") (datasheet "")
      (pins
        (pin (num 1) (name VCC) (type PWR) (net VCC_3V3))
        (pin (num 2) (name GND) (type PWR) (net GND))
        (pin (num 3) (name SDA) (type I/O) (net I2C_TCA_CH3))
        (pin (num 4) (name SCL) (type I/O) (net I2C_TCA_CH3))
        (pin (num 5) (name VBAT) (type PWR) (net RTC_VBAT))
      )
    )

    ; GPS HGLRC M100-5883 (UART)
    (comp (ref U_GPS) (value "HGLRC_M100-5883") (footprint "Module:GPS_HGLRC_M100") (datasheet "")
      (pins
        (pin (num 1) (name VCC) (type PWR) (net VCC_3V3))
        (pin (num 2) (name GND) (type PWR) (net GND))
        (pin (num 3) (name TX) (type I/O) (net UART1_RX))
        (pin (num 4) (name RX) (type I/O) (net UART1_TX))
        (pin (num 5) (name PPS) (type I/O) (net UNUSED))
        (pin (num 6) (name ANT) (type PASSIVE) (net ANT_GPS))
      )
    )

    ; LLCC68 LoRa (SPI)
    (comp (ref U_LORA) (value "LLCC68") (footprint "Module:LLCC68") (datasheet "")
      (pins
        (pin (num 1) (name VCC) (type PWR) (net VCC_3V3))
        (pin (num 2) (name GND) (type PWR) (net GND))
        (pin (num 3) (name SCK) (type I/O) (net SPI_SCK))
        (pin (num 4) (name MOSI) (type I/O) (net SPI_MOSI))
        (pin (num 5) (name MISO) (type I/O) (net SPI_MISO))
        (pin (num 6) (name CS) (type I/O) (net LORA_CS))
        (pin (num 7) (name IRQ) (type I/O) (net UNUSED))
        (pin (num 8) (name ANT) (type PASSIVE) (net ANT_LORA))
      )
    )

    ; microSD card breakout (SPI)
    (comp (ref U_SD) (value "microSD_SPI") (footprint "microSD:MicroSD_Card") (datasheet "")
      (pins
        (pin (num 1) (name VCC) (type PWR) (net VCC_3V3))
        (pin (num 2) (name GND) (type PWR) (net GND))
        (pin (num 3) (name CS) (type I/O) (net SD_CS))
        (pin (num 4) (name MOSI) (type I/O) (net SPI_MOSI))
        (pin (num 5) (name MISO) (type I/O) (net SPI_MISO))
        (pin (num 6) (name SCK) (type I/O) (net SPI_SCK))
      )
    )

    ; Pyro driver MOSFET + optocoupler block
    (comp (ref U_OPTO) (value "Optocoupler") (footprint "DIP-4:4") (datasheet "")
      (pins
        (pin (num 1) (name ANODE) (type I/O) (net PYRO_CTRL))
        (pin (num 2) (name CATHODE) (type I/O) (net GND))
        (pin (num 3) (name OUT+) (type I/O) (net PYRO_PWR_CTRL))
        (pin (num 4) (name OUT-) (type I/O) (net GND))
      )
    )
    (comp (ref Q_PYRO) (value "IRLZ44N/MOSFET") (footprint "TO-220:IRLZ44") (datasheet "")
      (pins
        (pin (num 1) (name G) (type I/O) (net PYRO_PWR_CTRL))
        (pin (num 2) (name D) (type PWR) (net PYRO_PLUS))
        (pin (num 3) (name S) (type PWR) (net GND))
      )
    )

    ; LR7843 pyro module (pyro load)
    (comp (ref PYRO1) (value "LR7843_module") (footprint "Module:LR7843") (datasheet "")
      (pins
        (pin (num 1) (name +) (type PWR) (net PYRO_PLUS))
        (pin (num 2) (name -) (type PWR) (net GND))
        (pin (num 3) (name TRIG) (type I/O) (net PYRO_CTRL_IN))
      )
    )

    ; Antenna connectors
    (comp (ref J_ANT_GPS) (value "u.FL") (footprint "Connector:u.FL") (datasheet "")
      (pins (pin (num 1) (name ANT) (type PASSIVE) (net ANT_GPS)) (pin (num 2) (name GND) (type PWR) (net GND)))
    (comp (ref J_ANT_LORA) (value "u.FL") (footprint "Connector:u.FL") (datasheet "")
      (pins (pin (num 1) (name ANT) (type PASSIVE) (net ANT_LORA)) (pin (num 2) (name GND) (type PWR) (net GND)))

    ; Testpoints
    (comp (ref TP_BAT) (value "TP") (footprint "Testpoint:Testpoint_Pin") (datasheet "")
      (pins (pin (num 1) (name 1) (type PASSIVE) (net BAT+)))
    (comp (ref TP_5V) (value "TP") (footprint "Testpoint:Testpoint_Pin") (datasheet "")
      (pins (pin (num 1) (name 1) (type PASSIVE) (net VIN_5V)))
    (comp (ref TP_3V3) (value "TP") (footprint "Testpoint:Testpoint_Pin") (datasheet "")
      (pins (pin (num 1) (name 1) (type PASSIVE) (net VCC_3V3)))

  )

  ; No wires section in this netlist text; nets defined above map to component pins by net names.
)